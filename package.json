{
	"name": "@pawells/rxjs-events",
	"displayName": "RxJS Events",
	"version": "1.0.0",
	"description": "RxJS-based event handling library with reactive observables and async event streams.",
	"type": "module",
	"main": "./build/index.js",
	"types": "./build/index.d.ts",
	"exports": {
		".": {
			"types": "./build/index.d.ts",
			"import": "./build/index.js"
		}
	},
	"scripts": {
		"build": "tsc --project tsconfig.lib.json",
		"start": "node build/index.js",
		"dev": "tsc --project tsconfig.lib.json && node build/index.js",
		"watch": "tsc --watch --project tsconfig.lib.json",
		"typecheck": "tsc --project tsconfig.spec.json --noEmit",
		"lint": "eslint src/",
		"lint:fix": "eslint src/ --fix",
		"test": "vitest run",
		"test:ui": "vitest --ui",
		"test:coverage": "vitest --coverage",
		"prepublishOnly": "yarn build",
		"prepare": "husky"
	},
	"dependencies": {
		"rxjs": "^7.8.2"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@stylistic/eslint-plugin": "^5.9.0",
		"@types/node": "^25.3.0",
		"@typescript-eslint/eslint-plugin": "^8.0.0",
		"@typescript-eslint/parser": "^8.0.0",
		"@vitest/coverage-v8": "^4.0.18",
		"@vitest/ui": "^4.0.18",
		"eslint": "^10.0.1",
		"eslint-import-resolver-typescript": "^4.4.4",
		"eslint-plugin-import": "^2.31.0",
		"eslint-plugin-unused-imports": "^4.0.0",
		"globals": "^17.3.0",
		"husky": "^9.1.7",
		"typescript": "^5.3.3",
		"vitest": "^4.0.18"
	},
	"keywords": [
		"typescript",
		"rxjs",
		"events",
		"observables",
		"async",
		"reactive",
		"esm"
	],
	"author": "Phillip Aaron Wells",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/PhillipAWells/rxjs-events.git"
	},
	"bugs": {
		"url": "https://github.com/PhillipAWells/rxjs-events/issues"
	},
	"homepage": "https://github.com/PhillipAWells/rxjs-events#readme",
	"engines": {
		"node": ">=22.0.0"
	},
	"files": [
		"build/",
		"README.md",
		"LICENSE"
	],
	"publishConfig": {
		"access": "public"
	}
}
